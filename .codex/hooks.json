{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.env|*.env.*) echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\".env files are protected. Ask Jordan before editing.\"}}';; *) echo '{}';; esac; }",
            "statusMessage": "Checking .env protection..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/jordancole/Documents/Developement/Projects/Shmocard/Shmo Website/.codex/hooks/screenshot-reminder.sh'",
            "statusMessage": "Checking if screenshot is needed..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/jordancole/Documents/Developement/Projects/Shmocard/Shmo Website/.codex/hooks/surface-applied-rules.sh'",
            "statusMessage": "Requiring rule surfacing..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/jordancole/Documents/Developement/Projects/Shmocard/Shmo Website/.codex/hooks/sweep-screenshots.sh'"
          },
          {
            "type": "command",
            "command": "'/Users/jordancole/Documents/Developement/Projects/Shmocard/Shmo Website/.codex/hooks/typecheck-on-stop.sh'",
            "statusMessage": "Running TypeScript typecheck..."
          }
        ]
      }
    ]
  }
}

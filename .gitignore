# Non-runtime: Claude Code dev tooling
# Only `.claude/skills/shmocard-design-system/` is runtime (imported by app/globals.css).
# Everything else under `.claude/` is local-only Claude Code config.
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/shmocard-design-system/

# Non-runtime: Codex tooling
.codex/
.agents/

# Non-runtime: GSD planning artifacts
.planning/

# Non-runtime: long-form project context (kept local, not in GitHub)
context/

# Non-runtime: reference assets (mockups, mascots, references — not served by Next.js)
# `public/` is the runtime static folder and stays tracked.
pictures/

# Non-runtime: agent / MCP instructions (kept local)
CLAUDE.md
AGENTS.md
.mcp.json
